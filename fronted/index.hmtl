<!DOCTYPE html>
<html>
<head>
    <title>Smart Grid Dashboard</title>
</head>
<body>

<h1>Smart Grid Dashboard</h1>

<button onclick="turnOn()">Turn ON</button>
<button onclick="turnOff()">Turn OFF</button>

<h2>Status: <span id="status">Loading...</span></h2>

<h3>Latest Data:</h3>
<pre id="output"></pre>

<script>
function loadData() {
    fetch('http://127.0.0.1:8000/api/data/all/')
    .then(res => res.json())
    .then(data => {
        document.getElementById("output").textContent =
            JSON.stringify(data[data.length - 1], null, 2);
    });
}

function updateStatus() {
    fetch('http://127.0.0.1:8000/api/device/status/')
    .then(res => res.json())
    .then(data => {
        document.getElementById("status").textContent =
            data.on ? "ON" : "OFF";
    });
}

function turnOn() {
    fetch('http://127.0.0.1:8000/api/device/on/', {method: 'POST'});
}

function turnOff() {
    fetch('http://127.0.0.1:8000/api/device/off/', {method: 'POST'});
}

// Auto refresh every 3 seconds
setInterval(() => {
    loadData();
    updateStatus();
}, 3000);
</script>

</body>
</html>