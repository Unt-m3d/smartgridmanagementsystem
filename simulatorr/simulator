import requests
import random
import time

while True:
    voltage = random.uniform(210, 240)
    current = random.uniform(0.5, 5)
    power = voltage * current

    data = {
        "voltage": voltage,
        "current": current,
        "power": power
    }
    try:
        response = requests.post(
            "http://127.0.0.1:8000/api/data/",
            json=data
        )
        print("Sent:", data)
    except:
        print("Server not reachable")

    time.sleep(5)